{
  "name": "electron-stagewright-workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Workspace root for Electron Stagewright — drive Electron apps the way Playwright drives browsers.",
  "license": "MIT",
  "author": "johnny4young <asesordeprogramacion@gmail.com>",
  "homepage": "https://github.com/electron-stagewright/electron-stagewright",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/electron-stagewright/electron-stagewright.git"
  },
  "bugs": {
    "url": "https://github.com/electron-stagewright/electron-stagewright/issues"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  },
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "build": "pnpm -r build",
    "start": "node packages/core/dist/cli.js",
    "lint": "eslint .",
    "typecheck": "pnpm -r typecheck && pnpm typecheck:tests",
    "typecheck:tests": "tsc -p tsconfig.tests.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "matrix": "pnpm --filter @electron-stagewright/framework-matrix matrix",
    "bench": "pnpm --filter @electron-stagewright/bench bench",
    "bench:check": "pnpm --filter @electron-stagewright/bench bench:check",
    "docs:tools": "tsx packages/core/src/manifest/gen-tool-reference.ts TOOL-REFERENCE.md",
    "verify": "pnpm build && pnpm lint && pnpm typecheck && pnpm test && pnpm format:check",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-push": "pnpm verify"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.3",
    "@types/node": "^24.13.1",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "prettier": "^3.8.4",
    "simple-git-hooks": "^2.13.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
