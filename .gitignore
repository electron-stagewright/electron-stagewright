node_modules/
.pnpm-store/

# Build output
dist/
build/
*.tsbuildinfo

# Test output
coverage/
.vitest-cache/

# Review / verification artifacts (screenshots, traces captured during validation)
output/

# Editor / OS
.DS_Store
Thumbs.db
