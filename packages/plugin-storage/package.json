{
  "name": "@electron-stagewright/plugin-storage",
  "version": "0.3.0",
  "description": "Storage plugin for Electron Stagewright: read, seed, and assert an Electron app's cookies, storage snapshot, per-key localStorage/sessionStorage, and IndexedDB for agent-driven testing.",
  "type": "module",
  "license": "MIT",
  "author": "johnny4young <johnny.iv.young@gmail.com>",
  "homepage": "https://github.com/electron-stagewright/electron-stagewright",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/electron-stagewright/electron-stagewright.git",
    "directory": "packages/plugin-storage"
  },
  "bugs": {
    "url": "https://github.com/electron-stagewright/electron-stagewright/issues"
  },
  "keywords": [
    "electron",
    "mcp",
    "stagewright",
    "storage",
    "cookies",
    "testing",
    "ai-agent"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@electron-stagewright/core": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "fake-indexeddb": "^6.2.5"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
