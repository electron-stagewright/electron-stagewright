{
  "name": "@electron-stagewright/plugin-trace",
  "version": "0.0.0",
  "description": "Trace plugin for Electron Stagewright: record a driving session to JSONL, report token usage, and replay the recorded tool calls.",
  "type": "module",
  "license": "MIT",
  "author": "johnny4young <johnny.iv.young@gmail.com>",
  "homepage": "https://github.com/electron-stagewright/electron-stagewright",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/electron-stagewright/electron-stagewright.git",
    "directory": "packages/plugin-trace"
  },
  "bugs": {
    "url": "https://github.com/electron-stagewright/electron-stagewright/issues"
  },
  "keywords": [
    "electron",
    "mcp",
    "stagewright",
    "trace",
    "observability",
    "tokens",
    "ai-agent"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@electron-stagewright/core": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
